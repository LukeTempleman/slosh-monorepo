{
  "info": {
    "name": "Slosh Backend - Flask PostgreSQL API",
    "description": "Complete API testing collection with JWT authentication and admin role management",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Register a new user account"
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"adminpass123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Register an admin user account"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login and receive JWT token"
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"adminpass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login as admin and receive JWT token"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Get current authenticated user profile"
          }
        }
      ]
    },
    {
      "name": "User Secret Key Management",
      "item": [
        {
          "name": "Set My Secret Key",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secret_key\": \"my-super-secret-key-1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/me/secret-key",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me",
                "secret-key"
              ]
            },
            "description": "Set your own custom secret key (min 16 characters)"
          }
        },
        {
          "name": "Generate My Secret Key",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me/secret-key/generate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me",
                "secret-key",
                "generate"
              ]
            },
            "description": "Generate a random secret key for yourself"
          }
        },
        {
          "name": "Get My Secret Key",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me/secret-key",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me",
                "secret-key"
              ]
            },
            "description": "Get your own secret key"
          }
        },
        {
          "name": "Reset My Secret Key",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me/secret-key",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me",
                "secret-key"
              ]
            },
            "description": "Clear/reset your own secret key"
          }
        }
      ]
    },
    {
      "name": "Admin - User Management",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "users"
              ]
            },
            "description": "List all users in the system (admin only)"
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/users/{{user_id}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "users",
                "{{user_id}}",
                "role"
              ]
            },
            "description": "Update user role (admin or user). Replace {{user_id}} with actual user ID"
          }
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/users/{{user_id}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "users",
                "{{user_id}}",
                "status"
              ]
            },
            "description": "Update user active status. Replace {{user_id}} with actual user ID"
          }
        }
      ]
    },
    {
      "name": "Admin - User Secret Key Management",
      "item": [
        {
          "name": "Set User Secret Key",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secret_key\": \"user-secret-key-from-admin-1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/users/{{user_id}}/secret-key",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "users",
                "{{user_id}}",
                "secret-key"
              ]
            },
            "description": "Set a custom secret key for a user (admin only). Replace {{user_id}} with actual user ID"
          }
        },
        {
          "name": "Generate User Secret Key",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/users/{{user_id}}/secret-key/generate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "users",
                "{{user_id}}",
                "secret-key",
                "generate"
              ]
            },
            "description": "Generate a random secret key for a user (admin only). Replace {{user_id}} with actual user ID"
          }
        },
        {
          "name": "Get User Secret Key",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/users/{{user_id}}/secret-key",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "users",
                "{{user_id}}",
                "secret-key"
              ]
            },
            "description": "Get a user's secret key (admin only). Replace {{user_id}} with actual user ID"
          }
        },
        {
          "name": "Reset User Secret Key",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/users/{{user_id}}/secret-key",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "users",
                "{{user_id}}",
                "secret-key"
              ]
            },
            "description": "Clear/reset a user's secret key (admin only). Replace {{user_id}} with actual user ID"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT access token for authenticated user (obtained from login)"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string",
      "description": "JWT access token for admin user (obtained from admin login)"
    },
    {
      "key": "user_id",
      "value": "1",
      "type": "string",
      "description": "User ID for admin operations"
    }
  ]
}
