{
  "info": {
    "_postman_id": "slosh-multi-backend-collection",
    "name": "Slosh Multi-Backend API",
    "description": "Complete API collection for GONXT and Manufacturers backends",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
