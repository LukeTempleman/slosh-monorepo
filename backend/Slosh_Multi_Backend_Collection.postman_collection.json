  "item": [
    {
      "name": "GONXT Backend (Port 5000)",
      "item": [
        {
          "name": "Authentication",
          "item": [
            {
              "name": "Register User",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@gonxt.com\",\n  \"password\": \"admin@123\",\n  \"role\": \"admin\"\n}"
                },
                "url": {
                  "raw": "{{gonxt_url}}/api/auth/register",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "auth", "register"]
                }
              }
            },
            {
              "name": "Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const response = pm.response.json();",
                      "  pm.environment.set('gonxt_access_token', response.access_token);",
                      "  pm.environment.set('gonxt_refresh_token', response.refresh_token);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin@123\"\n}"
                },
                "url": {
                  "raw": "{{gonxt_url}}/api/auth/login",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "auth", "login"]
                }
              }
            },
            {
              "name": "Get Current User",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_access_token}}"
                  }
                ],
                "url": {
                  "raw": "{{gonxt_url}}/api/auth/me",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "auth", "me"]
                }
              }
            },
            {
              "name": "Refresh Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const response = pm.response.json();",
                      "  pm.environment.set('gonxt_access_token', response.access_token);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_refresh_token}}"
                  }
                ],
                "url": {
                  "raw": "{{gonxt_url}}/api/auth/refresh",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "auth", "refresh"]
                }
              }
            },
            {
              "name": "List All Users (Admin)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_access_token}}"
                  }
                ],
                "url": {
                  "raw": "{{gonxt_url}}/api/auth/admin/users",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "auth", "admin", "users"]
                }
              }
            },
            {
              "name": "Update User Role (Admin)",
              "request": {
                "method": "PATCH",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_access_token}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"role\": \"user\"\n}"
                },
                "url": {
                  "raw": "{{gonxt_url}}/api/auth/admin/users/{{user_id}}/role",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "auth", "admin", "users", "{{user_id}}", "role"]
                }
              }
            },
            {
              "name": "Update User Status (Admin)",
              "request": {
                "method": "PATCH",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_access_token}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"is_active\": true\n}"
                },
                "url": {
                  "raw": "{{gonxt_url}}/api/auth/admin/users/{{user_id}}/status",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "auth", "admin", "users", "{{user_id}}", "status"]
                }
              }
            }
          ]
        },
        {
          "name": "API Keys Management",
          "item": [
            {
              "name": "Create API Key",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  const response = pm.response.json();",
                      "  pm.environment.set('gonxt_api_key_id', response.id);",
                      "  pm.environment.set('gonxt_api_code', response.code);",
                      "  pm.environment.set('gonxt_api_manu_code', response.manufacturers_code);",
                      "  pm.environment.set('gonxt_api_verify_code', response.api_verification_code);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_access_token}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Payment Processing Key\",\n  \"description\": \"Key for integrating payment processing system\"\n}"
                },
                "url": {
                  "raw": "{{gonxt_url}}/api/keys",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "keys"]
                }
              }
            },
            {
              "name": "List API Keys",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_access_token}}"
                  }
                ],
                "url": {
                  "raw": "{{gonxt_url}}/api/keys",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "keys"]
                }
              }
            },
            {
              "name": "Get API Key Info",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_access_token}}"
                  }
                ],
                "url": {
                  "raw": "{{gonxt_url}}/api/keys/{{gonxt_api_key_id}}",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "keys", "{{gonxt_api_key_id}}"]
                }
              }
            },
            {
              "name": "Get All Codes (Authenticated)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_access_token}}"
                  }
                ],
                "url": {
                  "raw": "{{gonxt_url}}/api/keys/{{gonxt_api_key_id}}/codes",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "keys", "{{gonxt_api_key_id}}", "codes"]
                }
              }
            },
            {
              "name": "Verify Code (Public)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"code\": \"{{gonxt_api_verify_code}}\"\n}"
                },
                "url": {
                  "raw": "{{gonxt_url}}/api/keys/verify",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "keys", "verify"]
                }
              }
            },
            {
              "name": "Delete API Key",
              "request": {
                "method": "DELETE",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{gonxt_access_token}}"
                  }
                ],
                "url": {
                  "raw": "{{gonxt_url}}/api/keys/{{gonxt_api_key_id}}",
                  "host": ["{{gonxt_url}}"],
                  "path": ["api", "keys", "{{gonxt_api_key_id}}"]
                }
              }
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gonxt_url}}/api/health",
              "host": ["{{gonxt_url}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
