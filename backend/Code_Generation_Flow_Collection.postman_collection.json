    },
    {
      "key": "generated_code_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "generated_original_code",
      "value": "",
      "type": "string"
    },
    {
      "key": "generated_hashed_code",
      "value": "",
      "type": "string"
    }
  ]
}
